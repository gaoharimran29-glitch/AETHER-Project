# =============================================================================
# .dockerignore — AETHER
# Excludes files from Docker build context to keep image small and fast
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Frontend development files (production build is used instead)
frontend/node_modules
frontend/.env.local
frontend/.env.development
frontend/build

# Python cache and virtualenvs
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.Python
backend/.venv
backend/venv
backend/env
**/*.egg-info

# Test files (not needed in production image)
backend/test_aether.py
test_system.py
tests/

# Editor and OS files
.DS_Store
Thumbs.db
.vscode
.idea
*.swp
*.swo

# Documentation (not needed in container)
*.md
docs/

# Docker files themselves (no need to copy into image)
Dockerfile
docker-compose.yml
.dockerignore

# Logs
*.log
logs/